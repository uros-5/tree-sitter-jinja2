{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "jinja2",
      "camelcase": "Jinja2",
      "title": "Jinja2",
      "scope": "source.jinja2",
      "file-types": [
        "jinja2",
        "jinja"
      ],
      "injection-regex": "^jinja2$",
      "class-name": "TreeSitterJinja2"
    }
  ],
  "metadata": {
    "version": "0.0.14",
    "license": "MIT",
    "description": "Jinja2 grammar for tree-sitter",
    "authors": [
      {
        "name": "Uros Mrkobrada",
        "email": "uros.mrkobrada@gmail.com",
        "url": ""
      }
    ],
    "links": {
      "repository": "https://github.com/uros-5/tree-sitter-jinja2",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": true
  }
}